        <question>
            <text>Ce este `condition_variable`?</text>
            <answers>
                <answer correct='true'>o metoda de sincronizare care permite thread-urilor sa astepte ca o conditie sa se indeplineasca inainte de a avansa</answer>
                <answer>o variabilă globală folosită pentru comunicarea între thread-uri, de tip steag binar</answer>
                <answer>un tip special de mutex care blochează permanent accesul la memorie</answer>
            </answers>
        </question>
        <question>
            <text>Daca conditia e falsa, `condition_variable`:</text>
            <answers>
                <answer correct='true'>deschide mutex-ul</answer>
                <answer>inchide mutex-ul</answer>
                <answer>continua executia</answer>
            </answers>
        </question>
        <question>
            <text>
                Care este sintaxa pentru asteptarea pana ce o conditie devina adevarata, folosind `condition_variable`?
                ```cpp
                std::condition_variable cv;
                std::unoque_lock lock;
                ```
            </text>
            <answers>
                <answer correct='true'>`cv.wait(lock, [] {...});`</answer>
                <answer>`cv.await(lock, [] {...});`</answer>
                <answer>`cv.untill(lock, [] {...});`</answer>
            </answers>
        </question>
        <question>
            <text>Metodele `notify_one` si `notify_all` din `condition_variable`:</text>
            <answers>
                <answer correct='true'>permite altor thread-uri ce asteapta sa isi continue executia</answer>
                <answer>opreste executia altor thread-uri pentru ca thread-ul curent sa isi poata continua executia</answer>
                <answer>notifica programul curent de terminarea executiri thread-ului</answer>
            </answers>
        </question>
    </questions>
