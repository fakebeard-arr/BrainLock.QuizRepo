                <answer>Infiintarea unei Comunitati Europene de Aparare</answer>
                <answer>Votul majoritar in locul procedurii unanimitatii</answer>
                <answer correct=true>Unificarea comisiilor si consiliilor celor trei comunitati europene</answer>
            </answers>
        </question>
        <question>
            <topic>Istoric UE</topic>
            <text>Actul care a avut rolul de a unifica comisiile si consiliile celor trei comunitati europene poarta denumirea de:</text>
