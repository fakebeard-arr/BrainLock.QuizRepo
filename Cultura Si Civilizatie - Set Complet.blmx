    <contribuitors>@student_upt</contribuitors>
    <questions>
        <question>
            <topic>Concepte de baza</topic>
            <text>Deviza Uniunii Europene este:</text>
            <answers>
                <answer>E pluribus unum</answer>
                <answer correct=true>Unitate in diversitate</answer>
                <answer>Uniti vom invinge</answer>
            </answers>
        </question>
        <question>
            <topic>Concepte de baza</topic>
            <text>Conceptul de civilizatie desemneaza:</text>
            <answers>
                <answer>Creatiile sufletesti, spirituale, sistemele de idei si valori</answer>
                <answer correct=true>Creatiile materiale, mijloacele cu care omul isi adapteaza mediul inconjurator</answer>
                <answer>Totalitatea manifestarilor creatoare ale omului</answer>
            </answers>
        </question>
        <question>
            <topic>Concepte de baza</topic>
            <text>Conceptul de cultura desemneaza:</text>
            <answers>
                <answer>Creatiile materiale, mijloacele cu care omul isi adapteaza mediul inconjurator</answer>
                <answer>Manifestarile artistice ale fiintei umane</answer>
                <answer correct=true>Creatiile sufletesti, spirituale, sistemele de idei si valori</answer>
            </answers>
        </question>
        <question>
            <topic>Cultura europeana</topic>
            <text>Dupa Andrei Marga, comportamentul economic consacrat de cultura europeana este caracterizat de:</text>
            <answers>
                <answer correct=true>Rationalitate si rentabilitate</answer>
                <answer>Centralizare si dirijism</answer>
                <answer>Dominare a pietelor</answer>
            </answers>
        </question>
        <question>
            <topic>Cultura europeana</topic>
            <text>Dupa Andrei Marga, cultura politica europeana este caracterizata de:</text>
            <answers>
                <answer>Elitism</answer>
                <answer>Conservatorism</answer>
                <answer correct=true>Promovarea dezbaterii publice pe baza argumentelor</answer>
            </answers>
        </question>
        <question>
            <topic>Cultura europeana</topic>
            <text>Richard von Weizsacker afirma ca:</text>
            <answers>
                <answer>Europa fara Rusia este incompleta</answer>
                <answer>Europa se sfarseste la Zidul Berlinului</answer>
                <answer correct=true>Europa nu se reduce la Europa Occidentala</answer>
            </answers>
        </question>
        <question>
            <topic>Istoric UE</topic>
            <text>Comunitatea Europeana a Carbunelui si Otelului (CECO) a fost constituita in urma declaratiei ministrului francez de externe:</text>
            <answers>
                <answer>Charles de Gaulle</answer>
