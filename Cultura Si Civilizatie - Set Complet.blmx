        <question>
            <topic>Institutii UE</topic>
            <text>Comisia Europeana are atributia de a:</text>
            <answers>
                <answer correct=true>Formula propuneri de acte legislative si a le trimite spre adoptare Parlamentului si Consiliului Uniunii Europene</answer>
                <answer>Adopta legile propuse de Parlament si Consiliul Uniunii Europene</answer>
                <answer>Sanctiona incalcarea legislatiei comunitare</answer>
            </answers>
        </question>
        <question>
            <topic>Institutii UE</topic>
