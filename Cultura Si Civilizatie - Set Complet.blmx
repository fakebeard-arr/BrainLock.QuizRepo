        <question>
            <topic>Institutii UE</topic>
            <text>Printre atributiile Parlamentului European se numara cea de a:</text>
            <answers>
                <answer correct=true>Investiga plangerile cetatenilor Europeni</answer>
                <answer>Monitoriza toate institutiile, in special Comisia Europeana si Consiliul</answer>
