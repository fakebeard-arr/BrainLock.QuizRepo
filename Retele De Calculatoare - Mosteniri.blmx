            </answers>
        </question>
        <question>
            <text>Care din urmatoarele afirmatii referitoare la protocolul UDP este incorecta?</text>
            <answers>
                <answer correct=true>ofera fiabilitate crescuta</answer>
                <answer>are un adaos scazut de biti de control</answer>
                <answer>nu este orientat pe conexiune</answer>
                <answer>foloseste in structura antetului numere de porturi pentru sursa si destinatie</answer>
            </answers>
        </question>
