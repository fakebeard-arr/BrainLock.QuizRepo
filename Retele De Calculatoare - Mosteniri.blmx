        <question>
            <text>Cum difera comunicarea Multicast de comunicarea Broadcast?</text>
            <answers>
                <answer>Multicast are doi expeditori</answer>
                <answer>Broadcast trimite datele catre un singur receptor</answer>
                <answer correct=true>Multicast vizeaza un grup specific de receptori</answer>
