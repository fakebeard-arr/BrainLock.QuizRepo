        <question>
            <text>Cum functioneaza Modulatia Amplitudinii (AM)?</text>
            <answers>
                <answer correct=true>amplitudinea semnalului purtator e variata</answer>
                <answer>frecventa semnalului purtator e variata</answer>
                <answer>faza semnalului purtator e variata</answer>
            </answers>
        </question>
        <question>
            <text>Care mesaj DHCP este trimis de serverul DHCP ca raspuns la un mesaj `DHCP Discover`, care contine o oferta de adresa IP?</text>
            <answers>
                <answer>DHCP Decline</answer>
                <answer>DHCP Request</answer>
                <answer>DHCP Ack</answer>
                <answer correct=true>DHCP Offer</answer>
            </answers>
            <explanation>
                În procesul standard DHCP:
                - Clientul trimite `DHCP Discover` (caută servere DHCP)
                - Serverul răspunde cu `DHCP Offer` (oferă o adresă IP disponibilă)
                - Clientul trimite `DHCP Request` (acceptă oferta)
                - Serverul finalizează cu `DHCP ACK` (confirmă alocarea)
            </explanation>
        </question>
