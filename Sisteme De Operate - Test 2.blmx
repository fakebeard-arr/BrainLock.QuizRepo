    <title>Sisteme De Operate - Test 2</title>
    <questions>
        <question>
            <topic>Make</topic>
            <text>Ce este Make?</text>
            <answers>
                <answer correct=true>generator de comenzi</answer>
                <answer>compilator C/C++</answer>
                <answer>tool pentru urmarirea versiunilor</answer>
                <answer>text editor</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>Care este scopul Make?</text>
            <answers>
                <answer correct=true>generarea unei secvente de comenzi shell</answer>
                <answer>compilarea programelor C/C++</answer>
                <answer>urmarirea versiunilor unui proiect cu posibilitate de restaurare</answer>
                <answer>editarea fisierelor text</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>Pe baza a ce principui functioneaza Make?</text>
            <answers>
                <answer correct=true>determina relatiile de dependinta intre fisiere</answer>
                <answer>citeste fisierele pe rand si le trimite compilatorului</answer>
                <answer>nu ii pasa de relatiile dintre fisiere, doar salveaza versiunile</answer>
                <answer>deschide fiecare fisier in mod edit</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>Care e sintaxa corecta pentru Make?</text>
            <answers>
                <answer correct=true>
                    ```make
                    targets: requirements
                        command
                        command
                    ```
                </answer>
                <answer>
                    ```make
                    requirements: tragets
                        command
                        command
                    ```
                </answer>
                <answer>
                    ```make
                    command: requirements
                        end block
                    ```
                </answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>In sintaxa Make, ce reprezinta un target (tinta)?</text>
            <answers>
                <answer correct=true>unul sau mai multe nume de fisiere, separate prin spatiu</answer>
                <answer>unul sau mai multe nume de fisiere, separate prin virgula</answer>
                <answer>o comanda care se va executa</answer>
                <answer>un fisier pe care se bazeaza un alt fisier</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>In sintaza Make, ce reprezinta comenzile?</text>
            <answers>
                <answer correct=true>lista de pasi care genereaza fisierele din tinta</answer>
                <answer>comenzile care pregatesc codul pentru executie</answer>
                <answer>instructiuni pentru actualizarea sistemului Linux</answer>
                <answer>Make nu utilizeaza comenzi ci instructiuni</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>In sintaza make, ce reprezinta requirements (dependintele)?</text>
            <answers>
                <answer correct=true>nume de fisiere separate prin spatiu care trebuie sa existe inainte de a rula comenzile</answer>
                <answer> variabile de mediu pentru shell</answer>
                <answer>lista de unelte/compilatoare la care trebuie sa aiba acces Make</answer>
                <answer>referinte catre alte comenzi ce trebuie rulate</answer>
            </answers>
        </question>
        <question>
            <topic>Make</topic>
            <text>Ce afirmatie e adevarata despre comenzile Make?</text>
            <answers>
                <answer correct=true>fiecare linie de comenzi trebuie sa inceapa cu un caracter `TAB`</answer>
                <answer>nu poate sa contina comentarii</answer>
                <answer>nu poate contine referinte la alte comenzi</answer>
                <answer>este rulata de un interpretator intern Make</answer>
            </answers>
        </question>
